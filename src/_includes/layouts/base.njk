<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ site.tagline }}">
  <title>{{ title }} — {{ site.title }}</title>
  <link rel="stylesheet" href="{{ '/styles.css' | url }}">
</head>
<body class="{% if page.url == '/' %}page-home{% elif page.url == '/work/' %}page-work{% elif page.url == '/about/' %}page-about{% elif page.url == '/contact/' %}page-contact{% else %}page-entry{% endif %}">
  <header>
    <img class="header-avatar" src="{{ '/assets/liad/header-avatar.jpeg' | url }}" alt="{{ site.title }}">
    <h1>{{ site.title }}</h1>
    <p>{{ site.tagline }}</p>
    {% include "partials/nav.njk" %}
  </header>

  <main>
    {{ content | safe }}
  </main>

  {% if page.url != "/contact/" %}
    {% include "partials/mini-contact.njk" %}
  {% endif %}

  <footer>
    <p>&copy; {{ currentYear }} {{ site.author }}</p>
  </footer>

  <script src="{{ '/assets/scroll-reveal.js' | url }}" defer></script>
</body>
</html>
