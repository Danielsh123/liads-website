<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ site.tagline }}">
  <title>{{ title }} — {{ site.title }}</title>
  <link rel="stylesheet" href="{{ '/styles.css' | url }}">
</head>
<body>
  <header>
    <img class="header-avatar" src="{{ '/assets/liad/header-avatar.jpeg' | url }}" alt="{{ site.title }}">
    <h1>{{ site.title }}</h1>
    <p>{{ site.tagline }}</p>
    {% include "partials/nav.njk" %}
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <p>&copy; {{ currentYear }} {{ site.author }}</p>
  </footer>
</body>
</html>
