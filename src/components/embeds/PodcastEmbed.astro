---
import type { CollectionEntry } from "astro:content";

interface Props {
  data: CollectionEntry<"work">["data"];
}
const { data } = Astro.props;
---
<div class="embed embed-podcast">
  <span class="badge badge-podcast">🎙 פודקאסט</span>
  <iframe
    src={data.embedUrl}
    width="100%"
    height="152"
    frameborder="0"
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
    loading="lazy"
    title={data.title}></iframe>
</div>
