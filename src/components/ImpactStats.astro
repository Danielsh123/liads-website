---
import type { Bilingual, Stat } from "../data/content";

interface Props {
  heading: Bilingual;
  sub: Bilingual;
  stats: Stat[];
}
const { heading, sub, stats } = Astro.props;
---
<div style="text-align:center;margin-bottom:2.25rem;">
  <h2 data-en={heading.en} style="display:inline-block;width:auto;font-size:clamp(1.6rem,3.5vw,2.2rem);">{heading.he}</h2>
  <p data-en={sub.en} style="color:var(--color-text-muted);font-size:1.1rem;margin:0.5rem 0 0;">{sub.he}</p>
</div>
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1.25rem;">
  {
    stats.map((stat) => (
      <div class="ls-reveal" style="background:var(--color-surface);border-radius:var(--radius);padding:2rem 1.5rem;text-align:center;box-shadow:0 8px 26px rgba(27,36,52,0.07);border:1px solid rgba(27,36,52,0.04);">
        <div data-count={stat.target} data-suffix={stat.suffix} style="font-size:clamp(2.6rem,6vw,3.4rem);font-weight:900;line-height:1;background:var(--gradient-primary);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;">0</div>
        <div data-en={stat.label.en} style="font-weight:800;font-size:1.05rem;margin-top:0.6rem;color:var(--color-text);">{stat.label.he}</div>
        <div data-en={stat.sub.en} style="color:var(--color-text-muted);font-size:0.9rem;margin-top:0.35rem;">{stat.sub.he}</div>
      </div>
    ))
  }
</div>
