---
title: Home
layout: layouts/base.njk
permalink: /
---
<section class="intro">
  <p>Hi, I'm Liad. This is where I share bits of what I'm working on — podcast episodes, Instagram posts, and more.</p>
</section>

<section class="feed-preview">
  <h2>Latest</h2>
  <ul class="feed-list">
    {%- for entry in collections.feed | limit(3) %}
    {%- set title = entry.data.title %}
    {%- set embedType = entry.data.embedType %}
    {%- set embedUrl = entry.data.embedUrl %}
    {%- set sourceUrl = entry.data.sourceUrl %}
    {%- set thumbnail = entry.data.thumbnail %}
    <li class="feed-item">
      <h3>{{ title }}</h3>
      <p class="feed-item__date">{{ entry.data.date | readableDate }}</p>
      {%- if embedType == "podcast" %}
        {% include "partials/embed-podcast.njk" %}
      {%- elif embedType == "instagram" %}
        {% include "partials/embed-instagram.njk" %}
      {%- endif %}
      <p class="feed-item__caption">{{ entry.data.caption }}</p>
    </li>
    {%- endfor %}
  </ul>
  <p><a href="/work/">See all work &rarr;</a></p>
</section>
