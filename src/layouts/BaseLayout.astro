---
import { site } from "../config/site";
import { withBase } from "../lib/url";
import Nav from "../components/Nav.astro";
import MiniContact from "../components/MiniContact.astro";
import "../styles/global.css";

interface Props {
  title: string;
  /** Page-personality class on <body> (page-home, page-work, …). */
  bodyClass?: string;
  /** Contact page opts out — it already has the full CTA. */
  showMiniContact?: boolean;
}
const { title, bodyClass = "", showMiniContact = true } = Astro.props;
const currentYear = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={site.tagline} />
    <title>{title} — {site.title}</title>
  </head>
  <body class={bodyClass}>
    <header>
      <img
        class="header-avatar"
        src={withBase("/assets/liad/header-avatar.jpeg")}
        alt={site.title}
      />
      <h1>{site.title}</h1>
      <p>{site.tagline}</p>
      <Nav />
    </header>

    <main>
      <slot />
    </main>

    {showMiniContact && <MiniContact />}

    <footer>
      <p>&copy; {currentYear} {site.author}</p>
    </footer>

    <script>
      import "../scripts/scroll-reveal.ts";
    </script>
  </body>
</html>
