---
import Nav from "../components/Nav.astro";
import type { LandingNavLink } from "../lib/nav";
import "../../design/styles/global.css";

// Re-exported so pages can keep importing the type from the layout.
export type { LandingNavLink } from "../lib/nav";

interface Props {
  title: string;
  description?: string;
  /** Sticky-nav links for this page. */
  navLinks: LandingNavLink[];
}

const {
  title,
  description = "אהבת חינם, כאן ועכשיו — ליעד שפירא",
  navLinks,
} = Astro.props;
const year = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title} — ליעד שפירא</title>
  </head>
  <body>
    <div
      class="ls-root"
      style="min-height:100vh;background:var(--color-bg);overflow-x:hidden;"
    >
      <!-- ===== Sticky nav ===== -->
      <Nav navLinks={navLinks} />

      <slot />

      <footer style="text-align:center;">
        <p style="margin:0;font-weight:700;color:var(--color-text);" data-en="Senseless love, here and now.">אהבת חינם, כאן ועכשיו.</p>
        <p style="margin:0.4rem 0 0;" data-en={`© ${year} Liad Shapira · Built with love`}>© {year} ליעד שפירא · נבנה באהבה</p>
      </footer>
    </div>

    <script>
      // ---- Language toggle (he ⇄ en) -------------------------------------
      // Hebrew is server-rendered; each translatable node carries data-en
      // (and inputs data-en-ph). We cache the Hebrew on first switch and
      // swap textContent/placeholder + document direction. Choice persists.
      const LANG_KEY = "liad-lang";
      const numberEls = () =>
        Array.from(document.querySelectorAll<HTMLElement>("[data-count]"));

      function currentLang(): "he" | "en" {
        return document.documentElement.lang === "en" ? "en" : "he";
      }

      function renderCounts(lang: "he" | "en") {
        const locale = lang === "he" ? "he-IL" : "en-US";
        numberEls().forEach((el) => {
          const cur = el.dataset.current !== undefined ? Number(el.dataset.current) : 0;
          el.textContent = cur.toLocaleString(locale) + (el.dataset.suffix || "");
        });
      }

      function applyLang(lang: "he" | "en") {
        const he = lang === "he";
        document.documentElement.lang = lang;
        document.documentElement.dir = he ? "rtl" : "ltr";
        document.querySelectorAll<HTMLElement>("[data-en]").forEach((el) => {
          if (el.dataset.he === undefined) el.dataset.he = el.textContent || "";
          el.textContent = he ? el.dataset.he : el.dataset.en || "";
        });
        document.querySelectorAll<HTMLElement>("[data-en-ph]").forEach((el) => {
          if (el.dataset.hePh === undefined)
            el.dataset.hePh = el.getAttribute("placeholder") || "";
          el.setAttribute("placeholder", he ? el.dataset.hePh : el.dataset.enPh || "");
        });
        document
          .querySelectorAll<HTMLElement>("[data-lang-toggle]")
          .forEach((b) => (b.textContent = he ? "EN" : "עב"));
        renderCounts(lang);
        try {
          localStorage.setItem(LANG_KEY, lang);
        } catch {}
      }

      let stored: string | null = null;
      try {
        stored = localStorage.getItem(LANG_KEY);
      } catch {}
      if (stored === "en") applyLang("en");

      document.querySelectorAll("[data-lang-toggle]").forEach((btn) =>
        btn.addEventListener("click", () =>
          applyLang(currentLang() === "he" ? "en" : "he"),
        ),
      );

      // ---- Reveal on scroll ----------------------------------------------
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const lsReveals = Array.from(document.querySelectorAll<HTMLElement>(".ls-reveal"));
      const feedReveals = Array.from(
        document.querySelectorAll<HTMLElement>(".reveal:not(.ls-reveal)"),
      );

      if (reduce || !("IntersectionObserver" in window)) {
        lsReveals.forEach((el) => el.classList.add("ls-in"));
        feedReveals.forEach((el) => el.classList.add("is-visible"));
      } else {
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              el.classList.add(el.classList.contains("ls-reveal") ? "ls-in" : "is-visible");
              obs.unobserve(el);
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
        );
        lsReveals.forEach((el, i) => {
          el.style.animationDelay = (i % 4) * 0.08 + "s";
          obs.observe(el);
        });
        feedReveals.forEach((el) => obs.observe(el));
      }

      // ---- Count-up for impact stats -------------------------------------
      function runCounts() {
        const els = numberEls();
        if (!els.length) return;
        const targets = els.map((el) => Number(el.dataset.count));
        if (reduce) {
          els.forEach((el, i) => (el.dataset.current = String(targets[i])));
          renderCounts(currentLang());
          return;
        }
        const dur = 1400;
        const start = performance.now();
        const tick = (now: number) => {
          const p = Math.min(1, (now - start) / dur);
          const e = 1 - Math.pow(1 - p, 3);
          els.forEach((el, i) => (el.dataset.current = String(Math.round(targets[i] * e))));
          renderCounts(currentLang());
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }

      const impact = document.getElementById("impact");
      if (impact && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                runCounts();
                io.disconnect();
              }
            });
          },
          { threshold: 0.3 },
        );
        io.observe(impact);
      } else if (impact) {
        runCounts();
      }

      // ---- Contact form: client-side success state -----------------------
      const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
      if (form) {
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          form.hidden = true;
          const ok = document.querySelector<HTMLElement>("[data-form-success]");
          if (ok) ok.hidden = false;
        });
      }
    </script>
  </body>
</html>
