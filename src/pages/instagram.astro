---
import LandingLayout from "../layouts/LandingLayout.astro";
import type { LandingNavLink } from "../layouts/LandingLayout.astro";
import FeedItemInstagram from "../components/FeedItemInstagram.astro";
import MiniContact from "../components/MiniContact.astro";
import { withBase } from "../lib/url";
import { instagramPosts, instagramMiniContact } from "../data/content";

const navLinks: LandingNavLink[] = [
  { href: withBase("/"), label: "בית", en: "Home" },
  { href: withBase("/instagram/"), label: "אינסטגרם", en: "Instagram", active: true },
  { href: withBase("/podcasts/"), label: "פודקאסטים", en: "Podcasts" },
  { href: `${withBase("/")}#contact`, label: "צור קשר", en: "Contact" },
];
---
<LandingLayout title="אינסטגרם" navLinks={navLinks}>
  <!-- ===== Page header ===== -->
  <header style="position:relative;overflow:hidden;padding:clamp(2.5rem,6vw,4.5rem) 1.5rem;color:#fff;text-align:center;background:radial-gradient(circle at 12% 18%,rgba(255,255,255,0.2),transparent 42%),var(--gradient-instagram);">
    <span aria-hidden="true" style="position:absolute;top:-30px;right:8%;width:150px;height:150px;background:rgba(255,255,255,0.12);animation:ls-blob 15s ease-in-out infinite;"></span>
    <div style="position:relative;max-width:640px;margin:0 auto;">
      <span style="display:inline-block;font-weight:800;font-size:0.85rem;letter-spacing:0.06em;text-transform:uppercase;background:rgba(255,255,255,0.2);padding:0.4rem 1rem;border-radius:999px;margin-bottom:1rem;">📸 <span data-en="Instagram">אינסטגרם</span></span>
      <h1 data-en="Liad's feed" style="margin:0 0 0.75rem;font-size:clamp(2rem,5vw,3.2rem);font-weight:900;line-height:1.1;">הפיד של ליעד</h1>
      <p data-en="Moments from the field — good deeds, encounters, and hope. New followers are welcome to add a little more good to the world." style="margin:0;font-size:clamp(1rem,2vw,1.2rem);color:rgba(255,255,255,0.92);line-height:1.6;">רגעים מהשטח — מעשים טובים, מפגשים ותקווה. עוקבים חדשים מוזמנים לצרף עוד טוב לעולם.</p>
    </div>
  </header>

  <main style="max-width:var(--max-width-content);margin:0 auto;padding:clamp(2.5rem,5vw,4rem) 1.5rem 0;">
    <ul class="feed-list" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;">
      {instagramPosts.map((post) => <FeedItemInstagram post={post} />)}
    </ul>

    <MiniContact
      text={instagramMiniContact.text}
      ctaLabel={instagramMiniContact.ctaLabel}
      ctaHref={instagramMiniContact.ctaHref}
    />
  </main>
</LandingLayout>
