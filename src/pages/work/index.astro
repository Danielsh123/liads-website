---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeedList from "../../components/FeedList.astro";

const entries = (await getCollection("work")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---
<BaseLayout title="עבודות" bodyClass="page-work">
  <section class="feed">
    <h2 class="reveal">עבודות</h2>
    <FeedList entries={entries} headingLevel="h2" showBody={true} />
  </section>
</BaseLayout>
