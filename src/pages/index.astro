---
import LandingLayout from "../layouts/LandingLayout.astro";
import LandingHero from "../components/LandingHero.astro";
import ImpactStats from "../components/ImpactStats.astro";
import PillarCard from "../components/PillarCard.astro";
import Timeline from "../components/Timeline.astro";
import ContactForm from "../components/ContactForm.astro";
import { homeNavLinks, hero, impact, pillars, journey, contact } from "../data/content";
---
<LandingLayout title="בית" navLinks={homeNavLinks}>
  <!-- ===== Hero ===== -->
  <LandingHero
    kicker={hero.kicker}
    title={hero.title}
    bio={hero.bio}
    primaryCta={hero.primaryCta}
    secondaryCta={hero.secondaryCta}
    portrait={hero.portrait}
  />

  <main style="max-width:var(--max-width-content);margin:0 auto;padding:clamp(3rem,6vw,5rem) 1.5rem 0;">
    <!-- ===== Impact numbers ===== -->
    <section id="impact" style="margin-bottom:clamp(3.5rem,7vw,6rem);">
      <ImpactStats heading={impact.heading} sub={impact.sub} stats={impact.stats} />
    </section>

    <!-- ===== Pillars ===== -->
    <section id="pillars" style="margin-bottom:clamp(3.5rem,7vw,6rem);">
      <div style="text-align:center;margin-bottom:2.25rem;">
        <h2 data-en={pillars.heading.en} style="display:inline-block;width:auto;font-size:clamp(1.6rem,3.5vw,2.2rem);">{pillars.heading.he}</h2>
        <p data-en={pillars.sub.en} style="color:var(--color-text-muted);font-size:1.1rem;margin:0.5rem 0 0;">{pillars.sub.he}</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;">
        {
          pillars.items.map((p) => (
            <PillarCard icon={p.icon} grad={p.grad} title={p.title} body={p.body} tags={p.tags} />
          ))
        }
      </div>
    </section>

    <!-- ===== Timeline ===== -->
    <section id="journey" style="margin-bottom:clamp(3.5rem,7vw,6rem);">
      <div style="text-align:center;margin-bottom:2.75rem;">
        <h2 data-en={journey.heading.en} style="display:inline-block;width:auto;font-size:clamp(1.6rem,3.5vw,2.2rem);">{journey.heading.he}</h2>
        <p data-en={journey.sub.en} style="color:var(--color-text-muted);font-size:1.1rem;margin:0.5rem 0 0;">{journey.sub.he}</p>
      </div>
      <Timeline milestones={journey.milestones} />
    </section>

    <!-- ===== Contact / Spread the love ===== -->
    <section id="contact" style="margin-bottom:2.5rem;">
      <ContactForm heading={contact.heading} sub={contact.sub} success={contact.success} roleOptions={contact.roleOptions} />
    </section>
  </main>
</LandingLayout>
