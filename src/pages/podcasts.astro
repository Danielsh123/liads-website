---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FeedList from "../components/FeedList.astro";

// Dedicated podcast feed — same typed `work` collection, filtered to episodes.
const entries = (await getCollection("work"))
  .filter((entry) => entry.data.embedType === "podcast")
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="פודקאסטים" bodyClass="page-work">
  <section class="feed">
    <h2 class="reveal">פודקאסטים</h2>
    <FeedList entries={entries} headingLevel="h2" showBody={true} />
  </section>
</BaseLayout>
